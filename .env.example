# The publicly reachable URL Claude.ai (or any other MCP client) connects to.
# This is load-bearing for OAuth: it's embedded in the issuer/authorization
# server metadata and must match EXACTLY what the client connects to,
# scheme + host + (optional) port, no trailing slash.
#
# Examples:
#   https://ibkr-mcp.your-domain.com    -- public via reverse proxy with TLS
#   http://localhost:8000               -- local-only, no Claude.ai
PUBLIC_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# AUTH_MODE controls which auth mechanisms are accepted:
#   both    -- (default) accept either OAuth-issued tokens OR a static bearer
#              token. Best for "Claude.ai + scripts + Claude Code" mixed use.
#   oauth   -- only accept OAuth-issued tokens (requires LOGIN_PASSWORD).
#              Required for Claude.ai custom connectors.
#   bearer  -- only accept the static bearer token. Skips the OAuth dance;
#              good for CLI clients, your own scripts, and Claude Code.
AUTH_MODE=both

# --- OAuth mode (used by Claude.ai custom connectors) ----------------------
# Password for the /login consent step. Anyone with this password becomes
# the "demo-user" identity. Required if AUTH_MODE is "oauth" or "both" and
# you want the OAuth path to work.
LOGIN_PASSWORD=change-me

# Secret used to sign session cookies. Generate with:
#   uv run --no-project python -c "import secrets; print(secrets.token_urlsafe(48))"
# Optional. If unset, a fresh random one is generated at startup (so sessions
# don't survive restarts).
SESSION_SECRET=change-me-too

# --- Bearer mode (used by scripts, Claude Code, OpenAI MCP, etc.) ----------
# A long random string. Send it as `Authorization: Bearer <token>` against
# /mcp. Generate with:
#   uv run --no-project python -c "import secrets; print(secrets.token_urlsafe(48))"
STATIC_BEARER_TOKEN=

# ---------------------------------------------------------------------------
# IBKR / ib-gateway
# ---------------------------------------------------------------------------
# Your Interactive Brokers credentials. ib-gateway uses these to log in to
# IBKR -- the connector itself never sees them. Use a PAPER account for now.
TWS_USERID=
TWS_PASSWORD=

# paper | live | both. Leave on paper until everything works.
TRADING_MODE=paper

# yes | no. Keep "yes" for read-only access -- blocks order placement.
READ_ONLY_API=yes

# How the connector reaches ib-gateway. Defaults match this compose file;
# only change if you point the connector at an external ib-gateway.
# Inside the container, ib-gateway exposes the TWS API on 127.0.0.1:4001/4002
# and uses socat to relay it onto the network interface at :4003 (live) and
# :4004 (paper). The connector must use the socat ports.
IB_HOST=ib-gateway
IB_PORT=4004      # 4004 = paper (default), 4003 = live
IB_CLIENT_ID=7    # must be unique per TWS connection

